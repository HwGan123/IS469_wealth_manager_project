# Copy this file to .env and fill in your values

# --- Required API Keys ---
ANTHROPIC_API_KEY=
# Optional: use an Anthropic-compatible proxy or custom endpoint
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# Override the model name if your endpoint uses a different one
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
FINNHUB_API_KEY=
NEWS_API_KEY=

# --- Sentiment Model ---
# Public Hugging Face repo — no token needed
LLAMA_SENTIMENT_MODEL_PATH=lunn1212/llama3.2

# If you use a private HF repo, add your token:
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# --- Optional Tuning ---
# SENTIMENT_MAX_NEW_TOKENS_CLASSIFY=30
# SENTIMENT_CLASSIFY_BATCH_SIZE=16
# SENTIMENT_MAX_NEW_TOKENS_THEME=256
